  "dependencies": {
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "drizzle-orm": "^0.45",
    "better-sqlite3": "^11",
    "jose": "^6",
    "bcrypt": "^6",
    "zod": "^4",
    "lucide-react": "^0.562",
    "tailwind-merge": "^3",
    "clsx": "^2",
    "class-variance-authority": "^0.7",
    "sonner": "^2",
    "date-fns": "^4"
  },
  "devDependencies": {
    "vitest": "^4",
    "@vitest/ui": "^4",
    "@vitejs/plugin-react": "^5",
    "@playwright/test": "^1.57",
    "drizzle-kit": "^0.31",
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bcrypt": "^6",
